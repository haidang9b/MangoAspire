@model Mango.Web.Models.OrderDetailDto

@{
    ViewData["Title"] = "Order Details";
}

@* Page Header *@
<div class="mango-page-header mango-fade-in">
    <h1 class="mango-page-header__title">
        <i class="fa-solid fa-receipt"></i> Order Details
    </h1>
    <div class="mango-page-header__actions">
        @switch (Model.Status)
        {
            case "Processing":
                <span class="mango-badge mango-badge--warning">
                    <i class="fa-solid fa-hourglass-half"></i> Processing
                </span>
                break;
            case "Completed":
                <span class="mango-badge mango-badge--success">
                    <i class="fa-solid fa-circle-check"></i> Completed
                </span>
                break;
            case "Cancelled":
                <span class="mango-badge mango-badge--danger">
                    <i class="fa-solid fa-circle-xmark"></i> Cancelled
                </span>
                break;
            default:
                <span class="mango-badge mango-badge--neutral">@Model.Status</span>
                break;
        }
        <a asp-action="Index" class="mango-btn mango-btn--secondary mango-btn--sm">
            <i class="fa-solid fa-arrow-left"></i> Back to Orders
        </a>
    </div>
</div>

@* Cancellation Reason *@
@if (Model.Status == "Cancelled" && !string.IsNullOrEmpty(Model.CancelReason))
{
    <div class="mango-alert mango-alert--danger mango-fade-in" role="alert">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <div>
            <strong>Cancellation Reason</strong>
            <div style="margin-top:2px;font-size:0.875rem;">@Model.CancelReason</div>
        </div>
    </div>
}

@* Info Cards Row *@
<div class="row g-3 mb-4 mango-fade-in">

    @* Order Information *@
    <div class="col-md-6">
        <div class="mango-card mango-card--accent-top h-100">
            <div class="mango-card__header">
                <h2 class="mango-card__title">
                    <i class="fa-solid fa-circle-info ec-text-primary me-1"></i> Order Information
                </h2>
            </div>
            <div class="mango-card__body">
                <table class="w-100" style="border-collapse:collapse; font-size:0.9rem;">
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600; width:40%;">Order ID</td>
                        <td style="padding:.5rem .25rem; font-family:monospace; font-size:0.8rem; color:var(--ec-text);">@Model.Id</td>
                    </tr>
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Order Date</td>
                        <td style="padding:.5rem .25rem; color:var(--ec-text);">@Model.OrderTime.ToString("MMMM dd, yyyy HH:mm")</td>
                    </tr>
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Pickup Date</td>
                        <td style="padding:.5rem .25rem; color:var(--ec-text);">@Model.PickupDate.ToString("MMMM dd, yyyy")</td>
                    </tr>
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Payment</td>
                        <td style="padding:.5rem .25rem;">
                            @if (Model.PaymentStatus)
                            {
                                <span class="mango-badge mango-badge--success"><i class="fa-solid fa-check"></i> Paid</span>
                            }
                            else
                            {
                                <span class="mango-badge mango-badge--warning"><i class="fa-solid fa-clock"></i> Pending</span>
                            }
                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                    {
                        <tr>
                            <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Coupon</td>
                            <td style="padding:.5rem .25rem;">
                                <span class="mango-badge mango-badge--info">
                                    <i class="fa-solid fa-tag"></i> @Model.CouponCode
                                </span>
                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>

    @* Customer Information *@
    <div class="col-md-6">
        <div class="mango-card mango-card--accent-top h-100">
            <div class="mango-card__header">
                <h2 class="mango-card__title">
                    <i class="fa-solid fa-user ec-text-primary me-1"></i> Customer Information
                </h2>
            </div>
            <div class="mango-card__body">
                <table class="w-100" style="border-collapse:collapse; font-size:0.9rem;">
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600; width:40%;">Name</td>
                        <td style="padding:.5rem .25rem; color:var(--ec-text); font-weight:600;">@Model.FirstName @Model.LastName</td>
                    </tr>
                    <tr style="border-bottom:1px solid var(--ec-border);">
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Email</td>
                        <td style="padding:.5rem .25rem; color:var(--ec-text);">@Model.Email</td>
                    </tr>
                    <tr>
                        <td style="padding:.5rem .25rem; color:var(--ec-text-muted); font-weight:600;">Phone</td>
                        <td style="padding:.5rem .25rem; color:var(--ec-text);">@(Model.Phone ?? "N/A")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@* Order Items Table *@
<div class="mango-table-wrapper mango-fade-in">
    <div class="mango-card__header" style="padding:.875rem 1rem; border-bottom:1px solid var(--ec-border);">
        <h2 class="mango-card__title">
            <i class="fa-solid fa-box-open ec-text-primary me-1"></i> Order Items
        </h2>
    </div>

    <table class="mango-table" aria-label="Order items">
        <thead>
            <tr>
                <th style="width:48px;">#</th>
                <th>Product</th>
                <th style="text-align:center; width:100px;">Qty</th>
                <th style="text-align:right; width:120px;">Unit Price</th>
                <th style="text-align:right; width:120px;">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @{
                var index = 1;
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td style="color:var(--ec-text-muted); font-size:0.85rem;">@index</td>
                    <td style="font-weight:600;">@item.ProductName</td>
                    <td style="text-align:center;">
                        <span class="mango-badge mango-badge--neutral">@item.Count</span>
                    </td>
                    <td style="text-align:right; color:var(--ec-text-muted);">@string.Format("{0:c}", item.Price)</td>
                    <td style="text-align:right; font-weight:700; color:var(--ec-accent);">
                        @string.Format("{0:c}", item.Price * item.Count)
                    </td>
                </tr>
                index++;
            }
        </tbody>
        <tfoot>
            @if (Model.DiscountTotal > 0)
            {
                <tr style="background:var(--ec-success-light);">
                    <td colspan="4" style="padding:.875rem 1rem; text-align:right; font-weight:600; color:var(--ec-success);">
                        <i class="fa-solid fa-tag me-1"></i> Discount Applied
                    </td>
                    <td style="padding:.875rem 1rem; text-align:right; font-weight:700; color:var(--ec-success);">
                        &minus;@string.Format("{0:c}", Model.DiscountTotal)
                    </td>
                </tr>
            }
            <tr style="background:linear-gradient(135deg, var(--ec-primary) 0%, var(--ec-primary-hover) 100%);">
                <td colspan="4" style="padding:1rem; text-align:right; font-weight:700; color:#fff; font-size:1rem;">
                    Order Total
                </td>
                <td style="padding:1rem; text-align:right; font-weight:700; color:#fff; font-size:1.125rem;">
                    @string.Format("{0:c}", Model.OrderTotal)
                </td>
            </tr>
        </tfoot>
    </table>
</div>
