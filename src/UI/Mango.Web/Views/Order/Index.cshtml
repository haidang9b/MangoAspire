@model Mango.Web.Models.PaginatedItemsDto<Mango.Web.Models.OrderDto>

@{
    ViewData["Title"] = "My Orders";
}

<div class="mango-page-header mango-fade-in">
    <h1 class="mango-page-header__title">
        <i class="fa-solid fa-receipt"></i> My Orders
    </h1>
    <div class="mango-page-header__actions">
        <a asp-controller="Home" asp-action="Index" class="mango-btn mango-btn--secondary mango-btn--sm">
            <i class="fa-solid fa-bag-shopping"></i> Shop More
        </a>
    </div>
</div>

@if (Model == null || !Model.Data.Any())
{
    <div class="mango-alert mango-alert--info mango-fade-in" role="alert">
        <i class="fa-solid fa-circle-info"></i>
        <span>You haven't placed any orders yet. <a asp-controller="Home" asp-action="Index">Start shopping!</a></span>
    </div>
}
else
{
    <div class="mango-table-wrapper mango-fade-in">
        <table class="mango-table" aria-label="Order history">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th style="width:130px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Data)
                {
                    <tr>
                        <td>
                            <span style="font-family:monospace;font-size:0.8rem;color:var(--ec-text-muted);">
                                #@order.Id.ToString()[..8]…
                            </span>
                        </td>
                        <td>@order.OrderTime.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>
                            <span class="mango-badge mango-badge--neutral">@order.ItemCount item(s)</span>
                        </td>
                        <td style="font-weight:700;color:var(--ec-accent);">
                            @string.Format("{0:c}", order.OrderTotal)
                        </td>
                        <td>
                            @switch (order.Status)
                            {
                                case "Processing":
                                    <span class="mango-badge mango-badge--warning">
                                        <i class="fa-solid fa-hourglass-half"></i> Processing
                                    </span>
                                    break;
                                case "Completed":
                                    <span class="mango-badge mango-badge--success">
                                        <i class="fa-solid fa-circle-check"></i> Completed
                                    </span>
                                    break;
                                case "Cancelled":
                                    <span class="mango-badge mango-badge--danger">
                                        <i class="fa-solid fa-circle-xmark"></i> Cancelled
                                    </span>
                                    break;
                                default:
                                    <span class="mango-badge mango-badge--neutral">@order.Status</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id"
                               class="mango-btn mango-btn--secondary mango-btn--sm">
                                <i class="fa-solid fa-eye"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @* Pagination *@
        <nav class="mango-pagination" aria-label="Order pagination">
            <span class="mango-pagination__info">
                Showing @(((Model.PageIndex - 1) * Model.PageSize) + 1)–@Math.Min(Model.PageIndex * Model.PageSize, Model.Count)
                of @Model.Count orders
            </span>
            <ul class="mango-pagination__pages">
                <li>
                    <a class="mango-pagination__page-link @(!Model.HasPreviousPage ? "mango-pagination__page-link--disabled" : "")"
                       asp-action="Index" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-pageSize="@Model.PageSize">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li>
                        <a class="mango-pagination__page-link @(i == Model.PageIndex ? "mango-pagination__page-link--active" : "")"
                           asp-action="Index" asp-route-pageIndex="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li>
                    <a class="mango-pagination__page-link @(!Model.HasNextPage ? "mango-pagination__page-link--disabled" : "")"
                       asp-action="Index" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-pageSize="@Model.PageSize">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}
