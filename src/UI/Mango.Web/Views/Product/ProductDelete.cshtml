@model Mango.Web.Models.ProductDto

@{
    ViewData["Title"] = "Delete Product";
}

<div class="mango-page-header mango-fade-in">
    <h1 class="mango-page-header__title">Delete Product</h1>
    <div class="mango-page-header__actions">
        <a asp-action="ProductIndex" class="mango-btn mango-btn--secondary mango-btn--sm">
            <i class="fa-solid fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="form-card mango-fade-in" style="border-top-color: var(--ec-danger); max-width:560px;">
    <div class="form-card__header" style="background: var(--ec-danger-light);">
        <h2 class="form-card__title" style="color: var(--ec-danger);">
            <i class="fa-solid fa-triangle-exclamation"></i> Confirm Deletion
        </h2>
    </div>
    <div class="form-card__body">
        <p style="color:var(--ec-text-muted); font-size:0.9rem; margin-bottom:1.25rem;">
            You are about to permanently delete this product. This action cannot be undone.
        </p>

        <form asp-action="ProductDelete">
            <input asp-for="Id" hidden />

            <div class="mango-form__group">
                <label class="mango-form__label">Product Name</label>
                <input asp-for="Name" class="mango-form__input" disabled />
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="mango-form__group">
                        <label class="mango-form__label">Category</label>
                        <input asp-for="CategoryName" class="mango-form__input" disabled />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mango-form__group">
                        <label class="mango-form__label">Price</label>
                        <input asp-for="Price" class="mango-form__input" disabled />
                    </div>
                </div>
            </div>
            <div class="mango-form__group">
                <label class="mango-form__label">Description</label>
                <textarea asp-for="Description" class="mango-form__textarea" rows="3" disabled></textarea>
            </div>
            <div class="mango-form__group">
                <label class="mango-form__label">Image URL</label>
                <input asp-for="ImageUrl" class="mango-form__input" disabled />
            </div>

            <div class="form-card__footer">
                <button type="submit" class="mango-btn mango-btn--danger">
                    <i class="fa-solid fa-trash"></i> Delete Product
                </button>
                <a asp-action="ProductIndex" class="mango-btn mango-btn--secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
