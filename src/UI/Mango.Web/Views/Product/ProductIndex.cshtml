@model Mango.Web.Models.PaginatedItemsDto<ProductDto>

@{
    ViewData["Title"] = "Products";
    var catalogTypes = ViewBag.CatalogTypes as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var currentCatalogTypeId = Context.Request.Query["catalogTypeId"].FirstOrDefault();
}

<div class="mango-page-header mango-fade-in">
    <h1 class="mango-page-header__title">Products</h1>
    <div class="mango-page-header__actions">
        <a asp-action="ProductCreate" class="mango-btn mango-btn--primary mango-btn--sm">
            <i class="fa-solid fa-plus"></i> New Product
        </a>
    </div>
</div>

<div class="mango-table-wrapper mango-fade-in">

    @* Filter Bar *@
    <div class="mango-filter">
        <i class="fa-solid fa-filter ec-text-muted" style="font-size:.875rem;"></i>
        <form method="get" asp-action="ProductIndex" class="d-flex align-items-center gap-2">
            <select name="catalogTypeId"
                    class="mango-filter__select"
                    onchange="this.form.submit()"
                    aria-label="Filter by category">
                <option value="">All Categories</option>
                @if (catalogTypes != null)
                {
                    @foreach (var item in catalogTypes)
                    {
                        <option value="@item.Value" selected="@(item.Value == currentCatalogTypeId)">@item.Text</option>
                    }
                }
            </select>
            <input type="hidden" name="pageIndex" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
        </form>
    </div>

    @* Table *@
    <table class="mango-table" aria-label="Products table">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th style="width:120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Data.Any())
            {
                @foreach (var item in Model.Data)
                {
                    <tr>
                        <td>
                            <span style="font-weight:600;">@item.Name</span>
                        </td>
                        <td>
                            <span class="mango-badge mango-badge--neutral">@item.CategoryName</span>
                        </td>
                        <td>
                            <span style="font-weight:600; color:var(--ec-accent);">@item.Price.ToString("c")</span>
                        </td>
                        <td>
                            @if (item.Stock > 0)
                            {
                                <span class="mango-badge mango-badge--success">
                                    <i class="fa-solid fa-check"></i> @item.Stock
                                </span>
                            }
                            else
                            {
                                <span class="mango-badge mango-badge--danger">
                                    <i class="fa-solid fa-xmark"></i> Out of Stock
                                </span>
                            }
                        </td>
                        <td>
                            <div class="mango-table__actions">
                                <a asp-action="ProductEdit"
                                   asp-route-productId="@item.Id"
                                   class="mango-btn mango-btn--secondary mango-btn--icon"
                                   title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="ProductDelete"
                                   asp-route-productId="@item.Id"
                                   class="mango-btn mango-btn--danger mango-btn--icon"
                                   title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4" style="color:var(--ec-text-muted);">
                        <i class="fa-solid fa-box-open me-2"></i>No products found.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* Pagination *@
    @if (Model != null && Model.Data.Any())
    {
        <nav class="mango-pagination" aria-label="Product pagination">
            <span class="mango-pagination__info">
                Showing @(((Model.PageIndex - 1) * Model.PageSize) + 1)–@Math.Min(Model.PageIndex * Model.PageSize, Model.Count)
                of @Model.Count products
            </span>
            <ul class="mango-pagination__pages">
                <li>
                    <a class="mango-pagination__page-link @(!Model.HasPreviousPage ? "mango-pagination__page-link--disabled" : "")"
                       asp-action="ProductIndex" asp-route-pageIndex="@(Model.PageIndex - 1)"
                       asp-route-pageSize="@Model.PageSize" asp-route-catalogTypeId="@currentCatalogTypeId">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li>
                        <a class="mango-pagination__page-link @(i == Model.PageIndex ? "mango-pagination__page-link--active" : "")"
                           asp-action="ProductIndex" asp-route-pageIndex="@i"
                           asp-route-pageSize="@Model.PageSize" asp-route-catalogTypeId="@currentCatalogTypeId">@i</a>
                    </li>
                }
                <li>
                    <a class="mango-pagination__page-link @(!Model.HasNextPage ? "mango-pagination__page-link--disabled" : "")"
                       asp-action="ProductIndex" asp-route-pageIndex="@(Model.PageIndex + 1)"
                       asp-route-pageSize="@Model.PageSize" asp-route-catalogTypeId="@currentCatalogTypeId">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>