@* Auth-dependent nav items — rendered inside .mango-nav__links *@
@if (User.Identity.IsAuthenticated)
{
    <li>
        <a class="mango-nav__link" asp-controller="Cart" asp-action="Index" title="Your cart">
            <i class="fa-solid fa-cart-shopping"></i> Cart
        </a>
    </li>
    <li>
        <a class="mango-nav__link" asp-controller="Order" asp-action="Index" title="Your orders">
            <i class="fa-solid fa-receipt"></i> Orders
        </a>
    </li>
    <li>
        <span class="mango-nav__user">
            <i class="fa-solid fa-circle-user me-1"></i>@User.Identity.Name
        </span>
    </li>
    <li>
        <a class="mango-nav__link" asp-action="Logout" asp-controller="Home">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </li>
}
else
{
    <li>
        <a class="mango-nav__link" asp-action="Login" asp-controller="Home">
            <i class="fa-solid fa-right-to-bracket"></i> Sign In
        </a>
    </li>
}